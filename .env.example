# =============================================================
# Plataforma EAD Mentoria Fábio Borges — Variáveis de Ambiente
# =============================================================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local no repositório.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe — Price IDs dos planos (configurar no Stripe Dashboard)
STRIPE_PRICE_PRATA_MONTHLY=price_...
STRIPE_PRICE_PRATA_ANNUAL=price_...
STRIPE_PRICE_OURO_MONTHLY=price_...
STRIPE_PRICE_OURO_ANNUAL=price_...
STRIPE_PRICE_DIAMANTE_MONTHLY=price_...
STRIPE_PRICE_DIAMANTE_ANNUAL=price_...

# Checkout provider: 'stub' (dev sem credenciais) | 'stripe' | 'mercadopago'
CHECKOUT_PROVIDER=stub

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_WEBHOOK_SECRET=

# Resend
RESEND_API_KEY=
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=https://ead.fabioborgesoficial.com.br
