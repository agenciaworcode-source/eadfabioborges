# =============================================================
# Plataforma EAD Mentoria Fábio Borges — Variáveis de Ambiente
# =============================================================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local no repositório.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe — Price IDs dos planos (configurar no Stripe Dashboard)
STRIPE_PRICE_PRATA_MONTHLY=price_...
STRIPE_PRICE_PRATA_ANNUAL=price_...
STRIPE_PRICE_OURO_MONTHLY=price_...
STRIPE_PRICE_OURO_ANNUAL=price_...
STRIPE_PRICE_DIAMANTE_MONTHLY=price_...
STRIPE_PRICE_DIAMANTE_ANNUAL=price_...

# Checkout provider: 'stub' (dev sem credenciais) | 'pagarme' | 'stripe' | 'mercadopago'
CHECKOUT_PROVIDER=stub

# PagarMe v5 (provider recomendado)
# Obtenha no dashboard: https://beta.dashboard.pagar.me
PAGARME_API_KEY=sk_test_...                  # Chave secreta (sk_test_ sandbox | sk_ produção)
NEXT_PUBLIC_PAGARME_PUBLIC_KEY=pk_test_...   # Chave pública (tokenização de cartão no checkout transparente)
PAGARME_ACCOUNT_ID=acc_...                   # Account ID (dashboard PagarMe)
PAGARME_WEBHOOK_SECRET=                      # OBRIGATÓRIO em produção — sem ele o webhook rejeita (fail-closed)
PAGARME_ENV=sandbox                          # 'sandbox' | 'production' (deve casar com o prefixo da PAGARME_API_KEY)

# MercadoPago (legado)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_WEBHOOK_SECRET=

# Resend
RESEND_API_KEY=
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=https://ead.fabioborgesoficial.com.br
